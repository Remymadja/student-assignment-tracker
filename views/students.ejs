<%- include('partials/header') %><h1 class="fw-bold mb-3">Students</h1><div class="card rounded-4 shadow-sm"><div class="card-body"><table class="table"><thead><tr><th>Name</th><th>Email</th><th>Courses</th><th>Submissions</th><th>Average Grade</th></tr></thead><tbody><% students.forEach(s=>{ %><tr><td><%= s.name %></td><td><%= s.email %></td><td><%= s.courses %></td><td><%= s.submissions %></td><td><%= s.average_grade || '-' %></td></tr><% }) %></tbody></table></div></div><%- include('partials/footer') %>