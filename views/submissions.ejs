<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1 class="fw-bold mb-1">Submissions</h1>
    <p class="text-muted mb-0">Upload assignments, track status, grade submissions en voeg feedback toe.</p>
  </div>
</div>

<div class="card rounded-4 shadow-sm mb-4">
  <div class="card-body">
    <h2 class="h5 fw-bold mb-3">Add / Update Submission</h2>

    <form method="post" action="/submissions" enctype="multipart/form-data" class="row g-3">
      <div class="col-md-3">
        <label class="form-label">Assignment</label>
        <select name="assignment_id" class="form-select" required>
          <% assignments.forEach(a => { %>
            <option value="<%= a.id %>"><%= a.title %></option>
          <% }) %>
        </select>
      </div>

      <% if(user.role !== 'student') { %>
        <div class="col-md-3">
          <label class="form-label">Student</label>
          <select name="student_id" class="form-select" required>
            <% students.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %></option>
            <% }) %>
          </select>
        </div>
      <% } %>

      <div class="col-md-2">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option value="not_started">not_started</option>
          <option value="submitted" selected>submitted</option>
          <option value="graded">graded</option>
        </select>
      </div>

      <div class="col-md-4">
        <label class="form-label">Upload File</label>
        <input name="file" type="file" class="form-control">
      </div>

      <div class="col-md-10">
        <label class="form-label">Notes</label>
        <input name="notes" class="form-control" placeholder="Optional notes">
      </div>

      <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-success w-100">Save</button>
      </div>
    </form>
  </div>
</div>

<div class="card rounded-4 shadow-sm">
  <div class="card-body">
    <h2 class="h5 fw-bold mb-3">Submission List</h2>

    <table class="table align-middle">
      <thead>
        <tr>
          <th>Student</th>
          <th>Assignment</th>
          <th>Course</th>
          <th>Status</th>
          <th>Grade</th>
          <th>File</th>
          <th>Feedback / Action</th>
        </tr>
      </thead>
      <tbody>
        <% submissions.forEach(s => { %>
          <tr>
            <td><%= s.student %></td>
            <td><%= s.assignment %></td>
            <td><%= s.course %></td>
            <td>
              <span class="badge <%= s.status === 'graded' ? 'bg-success' : s.status === 'submitted' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                <%= s.status %>
              </span>
            </td>
            <td><%= s.grade ?? '-' %></td>
            <td>
              <% if(s.file_path) { %>
                <a href="/uploads/<%= s.file_path %>" target="_blank" class="btn btn-sm btn-outline-primary">
                  View File
                </a>
              <% } else { %>
                <span class="text-muted">No file</span>
              <% } %>
            </td>
            <td>
              <% if(user.role === 'admin' || user.role === 'teacher') { %>
                <form method="post" action="/submissions/<%= s.id %>/grade" class="d-flex gap-2">
                  <input name="grade" type="number" step="0.01" min="0" max="100" class="form-control form-control-sm" placeholder="Grade">
                  <input name="feedback" class="form-control form-control-sm" placeholder="Feedback">
                  <button class="btn btn-sm btn-outline-success">Grade</button>
                </form>
              <% } else { %>
                <%= s.feedback || '-' %>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>