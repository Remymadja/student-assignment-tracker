<%- include('partials/header') %>
<div class="row justify-content-center align-items-center login-wrap">
  <div class="col-md-5">
    <div class="card rounded-4 shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h3 text-success fw-bold">Student Assignment Tracker</h1>
        <p class="text-muted">Login to manage assignments, submissions and grades.</p>
        <form method="post" action="/login">
          <label class="form-label">Email</label>
          <input name="email" class="form-control mb-3" value="admin@example.com" required>
          <label class="form-label">Password</label>
          <input name="password" type="password" class="form-control mb-3" value="admin123" required>
          <button class="btn btn-success w-100">Login</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>