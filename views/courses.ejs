<%- include('partials/header') %><h1 class="fw-bold mb-3">Courses</h1><div class="card rounded-4 shadow-sm"><div class="card-body"><table class="table"><thead><tr><th>Code</th><th>Course</th><th>Teacher</th><th>Students</th><th>Assignments</th></tr></thead><tbody><% courses.forEach(c=>{ %><tr><td><%= c.code %></td><td><%= c.name %></td><td><%= c.teacher || '-' %></td><td><%= c.students %></td><td><%= c.assignments %></td></tr><% }) %></tbody></table></div></div><%- include('partials/footer') %>